      "targets": [
        {
          "editorMode": "code",
          "expr": "(1 - (node_memory_MemAvailable_bytes{environment=~\"$environment\",cluster=~\"$cluster\"} / node_memory_MemTotal_bytes{environment=~\"$environment\",cluster=~\"$cluster\"})) * 100",
          "legendFormat": "{{instance}}",
          "range": true,
          "refId": "A"
        }
      ],
