        {
          "editorMode": "code",
          "expr": "(1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\",mountpoint=\"/\",environment=~\"$environment\",cluster=~\"$cluster\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\",mountpoint=\"/\",environment=~\"$environment\",cluster=~\"$cluster\"})) * 100",
          "legendFormat": "{{instance}}",
          "range": true,
          "refId": "A"
