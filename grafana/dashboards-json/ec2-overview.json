        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by(instance) (rate(node_network_receive_bytes_total{device!~\"lo\",environment=~\"$environment\",cluster=~\"$cluster\"}[5m]))",
