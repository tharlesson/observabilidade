      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "editorMode": "code",
          "expr": "probe_duration_seconds{job=~\"blackbox-http|blackbox-tcp\",environment=~\"$environment\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Probe Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-central" },
