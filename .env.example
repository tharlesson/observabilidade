# Global
AWS_REGION=us-east-1
ENVIRONMENT=dev
TEAM=platform
CLUSTER=local-lab

# Prometheus remote_write / AMP
PROMETHEUS_REMOTE_WRITE_URL=https://aps-workspaces.us-east-1.amazonaws.com/workspaces/ws-xxxxxxxx/api/v1/remote_write
PROMETHEUS_REMOTE_WRITE_SIGV4_REGION=us-east-1

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
GF_SERVER_DOMAIN=grafana.local
GF_SERVER_ROOT_URL=https://grafana.local

# Internal auth (local lab defaults)
PROMETHEUS_BASIC_AUTH_USER=prom_admin
PROMETHEUS_BASIC_AUTH_PASSWORD=prom-admin-change-me
ALERTMANAGER_BASIC_AUTH_USER=alert_admin
ALERTMANAGER_BASIC_AUTH_PASSWORD=alert-admin-change-me

# Alertmanager webhook placeholders
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/replace/me
SMTP_SMARTHOST=smtp.example.com:587
SMTP_FROM=alertmanager@example.com
SMTP_AUTH_USERNAME=alertmanager@example.com
SMTP_AUTH_PASSWORD=change-me
ALERT_EMAIL_TO=oncall@example.com

# Local lab basic auth hashes (htpasswd bcrypt)
PROMETHEUS_BASIC_AUTH_HASH=
ALERTMANAGER_BASIC_AUTH_HASH=

# TLS certificate paths (local lab)
TLS_CERT_FILE=/etc/ssl/local/tls.crt
TLS_KEY_FILE=/etc/ssl/local/tls.key

# ECS
ECS_CLUSTER_NAME=observability-ecs
ECS_SUBNET_IDS=subnet-aaa,subnet-bbb
ECS_SECURITY_GROUP_ID=sg-xxx

# EKS
EKS_CLUSTER_NAME=observability-eks
