# Copy to terraform.tfvars and fill values for dev

aws_region   = "us-east-1"
environment  = "dev"
name_prefix  = "observability"
team         = "platform"

tags = {
  cost_center = "sre"
  owner       = "platform-team"
}

backend_mode                   = "amp"
remote_write_endpoint_override = ""

enable_eks_observability = true
enable_ecs_observability = true
enable_ec2_observability = true

kubeconfig_path    = "~/.kube/config"
kubeconfig_context = ""

eks_cluster_name            = "replace-with-eks-cluster-name"
eks_oidc_provider_arn       = "arn:aws:iam::<account-id>:oidc-provider/oidc.eks.<region>.amazonaws.com/id/<oidc-id>"
eks_oidc_provider_url       = "https://oidc.eks.<region>.amazonaws.com/id/<oidc-id>"
eks_observability_namespace = "observability"

enable_otel_operator    = true
enable_network_policies = true

ecs_cluster_name                  = "replace-with-ecs-cluster-name"
ecs_cluster_arn                   = "arn:aws:ecs:<region>:<account-id>:cluster/<cluster-name>"
ecs_subnet_ids                    = ["subnet-aaaa", "subnet-bbbb"]
ecs_security_group_ids            = ["sg-aaaa"]
ecs_assign_public_ip              = false
ecs_adot_desired_count            = 1
ecs_adot_task_cpu                 = 512
ecs_adot_task_memory              = 1024
ecs_adot_image                    = "public.ecr.aws/aws-observability/aws-otel-collector:v0.43.0"
# Prefer SSM parameter in prod to avoid inline config.
ecs_adot_config_content           = ""
ecs_adot_config_ssm_parameter_arn = ""

ecs_log_retention_days = 30

ec2_cluster_label           = "ec2-fleet"
ec2_target_tag_key          = "observability"
ec2_target_tag_value        = "enabled"
node_exporter_version       = "1.8.2"
ec2_otelcol_version         = "0.116.1"
ec2_collector_config_s3_uri = ""
ec2_collector_config_s3_arn = ""
